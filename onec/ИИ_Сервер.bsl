// =============================================================================
// Общий модуль ИИ_Сервер
//
// Серверные функции для выполнения кода через файл-дроппер.
// Используется обработкой ИИ_Песочница и через прямой вызов из COM.
//
// Свойства модуля в Конфигураторе:
//   Сервер: да
//   Внешнее соединение: да
//   Клиент (обычное приложение): нет
//   Вызов сервера: да
//
// Стратегия безопасности:
//   1. Проверка маркера [Тест] в названии информационной базы.
//      Если нет — пишем предупреждение в результат, но НЕ блокируем
//      (по решению пользователя — он берёт риск на себя).
//   2. Регекс-фильтра запрещённых конструкций НЕТ. Любую защиту
//      по тексту кода LLM может обойти склейкой строк, переименованием,
//      омоглифами. Реальная защита — на уровне ролей пользователя 1С
//      и регулярного бэкапа.
//   3. Транзакция вокруг каждого выполнения — при ошибке откат.
//   4. Запись в регистр ИИ_Действия для аудита.
// =============================================================================


// =============================================================================
// БУФЕР ВЫВОДА — для функции Вывести()
//
// Так как Выполнить() в 1С не имеет встроенного механизма возврата значения
// в вызывающий код, мы используем экспортную переменную модуля как буфер.
// Код задания может вызывать ИИ_Сервер.Вывести("текст") — это попадёт
// в результат под ключом output.
// =============================================================================

Перем БуферВывода Экспорт;


// Очищает буфер перед каждым выполнением
Процедура ОчиститьБуферВывода() Экспорт
    БуферВывода = "";
КонецПроцедуры


// Добавляет строку в буфер. Вызывается из кода задания.
// Параметры:
//   Значение - произвольное - что вывести (приведётся к строке)
Процедура Вывести(Значение) Экспорт
    Если БуферВывода = Неопределено Тогда
        БуферВывода = "";
    КонецЕсли;
    Если ЗначениеЗаполнено(БуферВывода) Тогда
        БуферВывода = БуферВывода + Символы.ПС;
    КонецЕсли;
    БуферВывода = БуферВывода + Строка(Значение);
КонецПроцедуры


// Возвращает накопленный вывод
Функция ПолучитьВывод() Экспорт
    Если БуферВывода = Неопределено Тогда
        Возврат "";
    КонецЕсли;
    Возврат БуферВывода;
КонецФункции


// =============================================================================
// Проверка тестовой базы
// =============================================================================

// Возвращает Истина если база содержит маркер [Тест] в названии конфигурации
// или строке соединения. Используется для предупреждения, но не блокирует.
Функция ЭтоТестоваяБаза() Экспорт
    Попытка
        ПредставлениеИБ = ПредставлениеИнформационнойБазы();
        Если СтрНайти(ВРег(ПредставлениеИБ), "[ТЕСТ]") > 0 Тогда
            Возврат Истина;
        КонецЕсли;
    Исключение
    КонецПопытки;

    Попытка
        Стр = СтрокаСоединенияИнформационнойБазы();
        Если СтрНайти(ВРег(Стр), "ТЕСТ") > 0 Тогда
            Возврат Истина;
        КонецЕсли;
    Исключение
    КонецПопытки;

    Возврат Ложь;
КонецФункции


// =============================================================================
// Получение текущего пользователя
// =============================================================================

// Возвращает ссылку на текущего пользователя или Неопределено.
// Подстраивается под наличие справочников Пользователи / Сотрудники.
Функция ПолучитьТекущегоПользователяСсылку() Экспорт
    Имя = ИмяПользователя();
    Попытка
        Ссылка = Справочники.Пользователи.НайтиПоНаименованию(Имя);
        Если Не Ссылка.Пустая() Тогда
            Возврат Ссылка;
        КонецЕсли;
    Исключение
    КонецПопытки;
    Попытка
        Ссылка = Справочники.Сотрудники.НайтиПоНаименованию(Имя);
        Если Не Ссылка.Пустая() Тогда
            Возврат Ссылка;
        КонецЕсли;
    Исключение
    КонецПопытки;
    Возврат Неопределено;
КонецФункции


// =============================================================================
// ВЫПОЛНЕНИЕ ЗАДАНИЯ ИЗ ФАЙЛА
//
// Параметры:
//   ПутьКФайлуЗадания - Строка - полный путь к JSON-файлу в inbox
//   ПапкаDone         - Строка - куда переместить файл после успеха
//   ПапкаErrors       - Строка - куда переместить при ошибке
//
// Возвращает: Структура (готова к сериализации в JSON)
//   task_id, status, executed_at, duration_ms, output, error,
//   warnings, snapshot_before, snapshot_after, screenshot_path
// =============================================================================
Функция ВыполнитьЗадание(ПутьКФайлуЗадания, ПапкаDone, ПапкаErrors) Экспорт

    Результат = Новый Структура;
    Результат.Вставить("task_id", "");
    Результат.Вставить("status", "error");
    Результат.Вставить("executed_at", ФорматДатыISO(ТекущаяДата()));
    Результат.Вставить("duration_ms", 0);
    Результат.Вставить("output", "");
    Результат.Вставить("error", "");
    Результат.Вставить("warnings", Новый Массив);
    Результат.Вставить("snapshot_before", "");
    Результат.Вставить("snapshot_after", "");
    Результат.Вставить("screenshot_path", "");

    // 1. Чтение файла задания
    ТекстЗадания = "";
    Попытка
        ЧтениеФайла = Новый ЧтениеТекста(ПутьКФайлуЗадания, КодировкаТекста.UTF8);
        ТекстЗадания = ЧтениеФайла.Прочитать();
        ЧтениеФайла.Закрыть();
    Исключение
        Результат.error = "Не удалось прочитать файл: " + ОписаниеОшибки();
        ПереместитьФайл_(ПутьКФайлуЗадания, ПапкаErrors);
        Возврат Результат;
    КонецПопытки;

    // 2. Парсинг JSON
    Задание = РазобратьJSON(ТекстЗадания);
    Если Задание = Неопределено Тогда
        Результат.error = "Не удалось распарсить JSON-задание";
        ПереместитьФайл_(ПутьКФайлуЗадания, ПапкаErrors);
        Возврат Результат;
    КонецЕсли;

    Результат.task_id = ПолучитьЗначение(Задание, "task_id", "");
    КодПрямой = ПолучитьЗначение(Задание, "code_forward", "");
    КодОбратный = ПолучитьЗначение(Задание, "code_backward", "");
    Комментарий = ПолучитьЗначение(Задание, "comment", "");

    // 3. Предупреждение если не тестовая база
    Если Не ЭтоТестоваяБаза() Тогда
        Результат.warnings.Добавить(
            "База не помечена маркером [Тест] в названии. Выполняем под ответственность пользователя.");
    КонецЕсли;

    // 4. Очистка буфера вывода перед запуском
    ОчиститьБуферВывода();

    // 5. Выполнение в транзакции
    ВремяСтарта = ТекущаяУниверсальнаяДатаВМиллисекундах();
    Попытка
        НачатьТранзакцию();
        Попытка
            // Само выполнение динамического кода. Обернём в Попытка-Исключение,
            // чтобы поймать рантайм-ошибки и сделать аккуратный rollback.
            ОбёрткаКода =
                "Попытка
                |    " + ЗаменитьПереводыСтрок(КодПрямой) + "
                |Исключение
                |    ВызватьИсключение ОписаниеОшибки();
                |КонецПопытки;";
            Выполнить(ОбёрткаКода);
            ЗафиксироватьТранзакцию();
            Результат.status = "success";
        Исключение
            ОтменитьТранзакцию();
            ВызватьИсключение;
        КонецПопытки;
    Исключение
        Результат.status = "runtime_error";
        Результат.error = ОписаниеОшибки();
    КонецПопытки;

    Результат.duration_ms = ТекущаяУниверсальнаяДатаВМиллисекундах() - ВремяСтарта;
    Результат.output = ПолучитьВывод();
    Результат.executed_at = ФорматДатыISO(ТекущаяДата());

    // 6. Запись в регистр ИИ_Действия (даже при ошибке — для аудита)
    ЗаписатьВЖурнал(Результат, КодПрямой, КодОбратный, Комментарий);

    // 7. Перемещение файла
    Если Результат.status = "success" Тогда
        ПереместитьФайл_(ПутьКФайлуЗадания, ПапкаDone);
    Иначе
        ПереместитьФайл_(ПутьКФайлуЗадания, ПапкаErrors);
    КонецЕсли;

    Возврат Результат;
КонецФункции


// =============================================================================
// ВЫПОЛНЕНИЕ ОБРАТНОГО КОДА (ОТКАТ)
//
// Параметры:
//   ИдентификаторЗадания - УникальныйИдентификатор - запись в регистре
//
// Возвращает: Структура (status, output, error, duration_ms)
// =============================================================================
Функция ВыполнитьОбратныйКод(ИдентификаторЗадания) Экспорт
    Результат = Новый Структура;
    Результат.Вставить("status", "error");
    Результат.Вставить("output", "");
    Результат.Вставить("error", "");
    Результат.Вставить("duration_ms", 0);

    // Найти запись
    Запрос = Новый Запрос;
    Запрос.Текст =
        "ВЫБРАТЬ
        |    Действия.КодОбратный,
        |    Действия.Комментарий,
        |    Действия.КодПрямой
        |ИЗ
        |    РегистрСведений.ИИ_Действия КАК Действия
        |ГДЕ
        |    Действия.ИдентификаторЗадания = &Идентификатор";
    Запрос.УстановитьПараметр("Идентификатор", ИдентификаторЗадания);
    Выборка = Запрос.Выполнить().Выбрать();

    Если Не Выборка.Следующий() Тогда
        Результат.error = "Запись с таким идентификатором не найдена";
        Возврат Результат;
    КонецЕсли;

    КодОбратный = Выборка.КодОбратный;
    Если Не ЗначениеЗаполнено(КодОбратный) Тогда
        Результат.error = "Обратный код не задан для этой записи";
        Возврат Результат;
    КонецЕсли;

    ОчиститьБуферВывода();
    ВремяСтарта = ТекущаяУниверсальнаяДатаВМиллисекундах();

    Попытка
        НачатьТранзакцию();
        Попытка
            ОбёрткаКода =
                "Попытка
                |    " + ЗаменитьПереводыСтрок(КодОбратный) + "
                |Исключение
                |    ВызватьИсключение ОписаниеОшибки();
                |КонецПопытки;";
            Выполнить(ОбёрткаКода);
            ЗафиксироватьТранзакцию();
            Результат.status = "rolled_back";
        Исключение
            ОтменитьТранзакцию();
            ВызватьИсключение;
        КонецПопытки;
    Исключение
        Результат.status = "rollback_failed";
        Результат.error = ОписаниеОшибки();
    КонецПопытки;

    Результат.duration_ms = ТекущаяУниверсальнаяДатаВМиллисекундах() - ВремяСтарта;
    Результат.output = ПолучитьВывод();

    // Обновляем статус оригинальной записи
    Попытка
        МенеджерЗаписи = РегистрыСведений.ИИ_Действия.СоздатьМенеджерЗаписи();
        МенеджерЗаписи.ИдентификаторЗадания = ИдентификаторЗадания;
        МенеджерЗаписи.Прочитать();
        Если МенеджерЗаписи.Выбран() Тогда
            МенеджерЗаписи.Статус = Результат.status;
            МенеджерЗаписи.Записать();
        КонецЕсли;
    Исключение
    КонецПопытки;

    Возврат Результат;
КонецФункции


// =============================================================================
// Запись в регистр сведений ИИ_Действия
// =============================================================================
Процедура ЗаписатьВЖурнал(Результат, КодПрямой, КодОбратный, Комментарий) Экспорт
    Попытка
        НоваяЗапись = РегистрыСведений.ИИ_Действия.СоздатьМенеджерЗаписи();

        Если ЗначениеЗаполнено(Результат.task_id) Тогда
            Попытка
                НоваяЗапись.ИдентификаторЗадания = Новый УникальныйИдентификатор(Результат.task_id);
            Исключение
                НоваяЗапись.ИдентификаторЗадания = Новый УникальныйИдентификатор;
            КонецПопытки;
        Иначе
            НоваяЗапись.ИдентификаторЗадания = Новый УникальныйИдентификатор;
        КонецЕсли;

        НоваяЗапись.Время = ТекущаяДата();
        НоваяЗапись.Пользователь = ПолучитьТекущегоПользователяСсылку();
        НоваяЗапись.Комментарий = Комментарий;
        НоваяЗапись.КодПрямой = КодПрямой;
        НоваяЗапись.КодОбратный = КодОбратный;
        НоваяЗапись.СнимокДо = Результат.snapshot_before;
        НоваяЗапись.СнимокПосле = Результат.snapshot_after;
        НоваяЗапись.Статус = Результат.status;
        НоваяЗапись.ТекстОшибки = Результат.error;
        НоваяЗапись.ДлительностьМс = Результат.duration_ms;
        НоваяЗапись.Записать();
    Исключение
        ЗаписьЖурналаРегистрации("ИИ_Сервер",
            УровеньЖурналаРегистрации.Ошибка,
            ,
            ,
            "Не удалось записать в регистр ИИ_Действия: " + ОписаниеОшибки());
    КонецПопытки;
КонецПроцедуры


// =============================================================================
// Записать результат выполнения в .result.json
// =============================================================================
Процедура ЗаписатьРезультат(ПутьРезультата, Результат) Экспорт
    Попытка
        JSON = СформироватьJSON(Результат);
        ЗаписьФайла = Новый ЗаписьТекста(ПутьРезультата, КодировкаТекста.UTF8);
        ЗаписьФайла.Записать(JSON);
        ЗаписьФайла.Закрыть();
    Исключение
        ЗаписьЖурналаРегистрации("ИИ_Сервер",
            УровеньЖурналаРегистрации.Ошибка,
            ,
            ,
            "Не удалось записать результат в " + ПутьРезультата + ": " + ОписаниеОшибки());
    КонецПопытки;
КонецПроцедуры


// =============================================================================
// JSON helpers
// =============================================================================

Функция РазобратьJSON(Текст) Экспорт
    Попытка
        Чтение = Новый ЧтениеJSON;
        Чтение.УстановитьСтроку(Текст);
        Результат = ПрочитатьJSON(Чтение, Истина);
        Чтение.Закрыть();
        Возврат Результат;
    Исключение
        Возврат Неопределено;
    КонецПопытки;
КонецФункции


Функция СформироватьJSON(ОбъектДанных) Экспорт
    ПараметрыЗаписи = Новый ПараметрыЗаписиJSON(ПереносСтрокJSON.Авто, "  ");
    Запись = Новый ЗаписьJSON;
    Запись.УстановитьСтроку(ПараметрыЗаписи);
    ЗаписатьJSON(Запись, ОбъектДанных);
    Возврат Запись.Закрыть();
КонецФункции


Функция ПолучитьЗначение(Структура, КлючИлиИндекс, ЗначениеПоУмолчанию)
    Попытка
        Если ТипЗнч(Структура) = Тип("Структура") Тогда
            Если Структура.Свойство(КлючИлиИндекс) Тогда
                Возврат Структура[КлючИлиИндекс];
            КонецЕсли;
        ИначеЕсли ТипЗнч(Структура) = Тип("Соответствие") Тогда
            Значение = Структура.Получить(КлючИлиИндекс);
            Если Значение <> Неопределено Тогда
                Возврат Значение;
            КонецЕсли;
        КонецЕсли;
    Исключение
    КонецПопытки;
    Возврат ЗначениеПоУмолчанию;
КонецФункции


// =============================================================================
// Утилиты
// =============================================================================

Функция ФорматДатыISO(Дата) Экспорт
    Возврат Формат(Дата, "ДФ='yyyy-MM-ddTHH:mm:ss'");
КонецФункции


Функция ЗаменитьПереводыСтрок(Текст)
    // На случай если в коде есть строки с | и переводами — оставим как есть.
    // Текст подаётся в Выполнить как есть.
    Возврат Текст;
КонецФункции


Процедура ПереместитьФайл_(ИсходныйПуть, ЦелеваяПапка)
    Попытка
        Если Не ПапкаСуществует(ЦелеваяПапка) Тогда
            СоздатьКаталог(ЦелеваяПапка);
        КонецЕсли;
        Файл = Новый Файл(ИсходныйПуть);
        ЦелевойПуть = ЦелеваяПапка + "\" + Файл.Имя;
        ПереместитьФайл(ИсходныйПуть, ЦелевойПуть);
    Исключение
        ЗаписьЖурналаРегистрации("ИИ_Сервер",
            УровеньЖурналаРегистрации.Предупреждение,
            ,
            ,
            "Не удалось переместить " + ИсходныйПуть + " в " + ЦелеваяПапка
            + ": " + ОписаниеОшибки());
    КонецПопытки;
КонецПроцедуры


Функция ПапкаСуществует(Путь) Экспорт
    Файл = Новый Файл(Путь);
    Возврат Файл.Существует() И Файл.ЭтоКаталог();
КонецФункции


// =============================================================================
// Сканирование inbox-папки
//
// Параметры:
//   ПапкаInbox - Строка - путь к папке inbox
//
// Возвращает: ТаблицаЗначений с колонками
//   ИмяФайла, Создано, Комментарий, ПутьФайла
// =============================================================================
Функция ПрочитатьInbox(ПапкаInbox) Экспорт
    Таблица = Новый ТаблицаЗначений;
    Таблица.Колонки.Добавить("ИмяФайла", Новый ОписаниеТипов("Строка"));
    Таблица.Колонки.Добавить("Создано", Новый ОписаниеТипов("Дата"));
    Таблица.Колонки.Добавить("Комментарий", Новый ОписаниеТипов("Строка"));
    Таблица.Колонки.Добавить("ПутьФайла", Новый ОписаниеТипов("Строка"));

    Если Не ПапкаСуществует(ПапкаInbox) Тогда
        Возврат Таблица;
    КонецЕсли;

    Файлы = НайтиФайлы(ПапкаInbox, "*.json");
    Для Каждого Файл Из Файлы Цикл
        Если Не Файл.ЭтоФайл() Тогда
            Продолжить;
        КонецЕсли;
        Стр = Таблица.Добавить();
        Стр.ИмяФайла = Файл.Имя;
        Стр.Создано = Файл.ПолучитьВремяИзменения();
        Стр.ПутьФайла = Файл.ПолноеИмя;

        // Прочитаем комментарий из JSON для удобства пользователя
        Попытка
            ЧтениеФайла = Новый ЧтениеТекста(Файл.ПолноеИмя, КодировкаТекста.UTF8);
            ТекстЗадания = ЧтениеФайла.Прочитать();
            ЧтениеФайла.Закрыть();
            Задание = РазобратьJSON(ТекстЗадания);
            Стр.Комментарий = ПолучитьЗначение(Задание, "comment", "");
        Исключение
            Стр.Комментарий = "(не удалось прочитать)";
        КонецПопытки;
    КонецЦикла;

    Таблица.Сортировать("Создано");
    Возврат Таблица;
КонецФункции


// =============================================================================
// Получение журнала действий за период
//
// Возвращает: ТаблицаЗначений с колонками
//   Время, Комментарий, Статус, Длительность, Идентификатор, КодПрямой, КодОбратный
// =============================================================================
Функция ПрочитатьЖурнал(НачалоПериода, КонецПериода) Экспорт
    Запрос = Новый Запрос;
    Запрос.Текст =
        "ВЫБРАТЬ
        |    Действия.Время,
        |    Действия.Комментарий,
        |    Действия.Статус,
        |    Действия.ДлительностьМс,
        |    Действия.ИдентификаторЗадания,
        |    Действия.КодПрямой,
        |    Действия.КодОбратный,
        |    Действия.ТекстОшибки
        |ИЗ
        |    РегистрСведений.ИИ_Действия КАК Действия
        |ГДЕ
        |    Действия.Время МЕЖДУ &Начало И &Конец
        |УПОРЯДОЧИТЬ ПО
        |    Действия.Время УБЫВ";
    Запрос.УстановитьПараметр("Начало", НачалоПериода);
    Запрос.УстановитьПараметр("Конец", КонецПериода);
    Возврат Запрос.Выполнить().Выгрузить();
КонецФункции


