// =============================================================================
// Модуль формы обработки ИИ_Песочница
//
// Обычная форма (не управляемая) — обработка inbox-папки с заданиями от ИИ.
//
// Реквизиты формы:
//   ПапкаДроппера   - Строка(500)
//   АвтоРежим       - Булево
//   ИнтервалОпроса  - Число(3,0)
//   СписокЗаданий   - ТаблицаЗначений (ИмяФайла, Создано, Комментарий, ПутьФайла)
//   Журнал          - ТаблицаЗначений (Время, Комментарий, Статус, ДлительностьМс,
//                                       ИдентификаторЗадания, КодПрямой, КодОбратный,
//                                       ТекстОшибки)
//
// Кнопки и их действия:
//   "Обновить"                   → ОбновитьСписокЗаданийНажатие
//   "Выполнить выделенное"       → ВыполнитьВыделенноеНажатие
//   "Выполнить всё"              → ВыполнитьВсёНажатие
//   "Обновить журнал"            → ОбновитьЖурналНажатие
//   "Откатить выделенное"        → ОткатитьВыделенноеНажатие
//   "Просмотр кода"              → ПросмотрКодаНажатие
//   "Повторить прямой код"       → ПовторитьПрямойНажатие
//
// Также: АвтоРежим.ПриИзменении → АвтоРежимПриИзменении
// =============================================================================


// При открытии формы — заполняем дефолтные значения
Процедура ПриОткрытии()
    Если Не ЗначениеЗаполнено(ПапкаДроппера) Тогда
        ПапкаДроппера = ПолучитьПутьПоУмолчанию();
    КонецЕсли;
    Если ИнтервалОпроса = 0 Тогда
        ИнтервалОпроса = 5;
    КонецЕсли;

    ПроверитьМаркерТеста();
    ОбновитьСписокЗаданий();
    ОбновитьЖурнал();
КонецПроцедуры


// Если база не помечена [Тест] — крупное предупреждение пользователю
Процедура ПроверитьМаркерТеста()
    Если Не ИИ_Сервер.ЭтоТестоваяБаза() Тогда
        Сообщить("ВНИМАНИЕ: эта база не помечена маркером [Тест] в названии. "
            + "Любые действия ИИ-ассистента изменят данные в этой базе. "
            + "Перед запуском убедитесь что у вас есть свежий бэкап.",
            СтатусСообщения.ОченьВажное);
    КонецЕсли;
КонецПроцедуры


// Путь по умолчанию — %LOCALAPPDATA%\1cMcpBridge\dropper\<DBKEY>
// DBKEY мы не знаем — пусть пользователь подставит сам, либо берём общий
Функция ПолучитьПутьПоУмолчанию()
    Попытка
        ПерменнаяОкружения = Новый COMОбъект("WScript.Shell");
        LocalAppData = ПерменнаяОкружения.ExpandEnvironmentStrings("%LOCALAPPDATA%");
        Возврат LocalAppData + "\1cMcpBridge\dropper\main";
    Исключение
        Возврат "C:\1cMcpBridge\dropper\main";
    КонецПопытки;
КонецФункции


// =============================================================================
// СПИСОК ЗАДАНИЙ
// =============================================================================

Процедура ОбновитьСписокЗаданийНажатие(Кнопка)
    ОбновитьСписокЗаданий();
КонецПроцедуры


Процедура ОбновитьСписокЗаданий()
    ПапкаInbox = ПапкаДроппера + "\inbox";
    Если Не ИИ_Сервер.ПапкаСуществует(ПапкаInbox) Тогда
        Сообщить("Папка inbox не существует: " + ПапкаInbox + ". Создайте её или измените путь.");
        СписокЗаданий.Очистить();
        Возврат;
    КонецЕсли;

    НоваяТаблица = ИИ_Сервер.ПрочитатьInbox(ПапкаInbox);
    СписокЗаданий.Очистить();
    Для Каждого Стр Из НоваяТаблица Цикл
        НоваяСтр = СписокЗаданий.Добавить();
        ЗаполнитьЗначенияСвойств(НоваяСтр, Стр);
    КонецЦикла;

    // Обновляем элемент управления формой
    ЭлементыФормы.СписокЗаданий.СоздатьКолонки();
КонецПроцедуры


Процедура ВыполнитьВыделенноеНажатие(Кнопка)
    ТекСтрока = ЭлементыФормы.СписокЗаданий.ТекущиеДанные;
    Если ТекСтрока = Неопределено Тогда
        Сообщить("Выделите задание в списке.");
        Возврат;
    КонецЕсли;
    ВыполнитьЗаданиеИзФайла(ТекСтрока.ПутьФайла);
    ОбновитьСписокЗаданий();
    ОбновитьЖурнал();
КонецПроцедуры


Процедура ВыполнитьВсёНажатие(Кнопка)
    Если СписокЗаданий.Количество() = 0 Тогда
        Сообщить("Нет заданий в inbox.");
        Возврат;
    КонецЕсли;

    Сообщить("Запускаю обработку " + СписокЗаданий.Количество() + " заданий...");

    // Копируем пути в массив, потому что в процессе таблица перерисуется
    Пути = Новый Массив;
    Для Каждого Стр Из СписокЗаданий Цикл
        Пути.Добавить(Стр.ПутьФайла);
    КонецЦикла;

    Для Каждого Путь Из Пути Цикл
        Файл = Новый Файл(Путь);
        Если Файл.Существует() Тогда
            ВыполнитьЗаданиеИзФайла(Путь);
        КонецЕсли;
    КонецЦикла;

    ОбновитьСписокЗаданий();
    ОбновитьЖурнал();
    Сообщить("Готово.");
КонецПроцедуры


// Главное действие — выполнить одно задание
Процедура ВыполнитьЗаданиеИзФайла(ПутьФайла)
    ПапкаDone = ПапкаДроппера + "\done";
    ПапкаErrors = ПапкаДроппера + "\errors";

    Сообщить("Выполняю: " + ПутьФайла);
    Результат = ИИ_Сервер.ВыполнитьЗадание(ПутьФайла, ПапкаDone, ПапкаErrors);

    // Записать .result.json рядом с заданием в done или errors
    ЦелеваяПапка = ?(Результат.status = "success", ПапкаDone, ПапкаErrors);
    ИмяФайла = СтрЗаменить(Новый Файл(ПутьФайла).Имя, ".json", ".result.json");
    ПутьРезультата = ЦелеваяПапка + "\" + ИмяФайла;
    ИИ_Сервер.ЗаписатьРезультат(ПутьРезультата, Результат);

    // Информируем пользователя
    СтатусТекст = "Статус: " + Результат.status + ", " + Результат.duration_ms + " мс";
    Если ЗначениеЗаполнено(Результат.error) Тогда
        СтатусТекст = СтатусТекст + Символы.ПС + "Ошибка: " + Результат.error;
    КонецЕсли;
    Если ЗначениеЗаполнено(Результат.output) Тогда
        СтатусТекст = СтатусТекст + Символы.ПС + "Вывод: " + Результат.output;
    КонецЕсли;
    Сообщить(СтатусТекст);
КонецПроцедуры


// =============================================================================
// АВТО-РЕЖИМ
// =============================================================================

Процедура АвтоРежимПриИзменении(Элемент)
    Если АвтоРежим Тогда
        Сообщить("Авто-режим включен. Опрос каждые " + ИнтервалОпроса + " секунд.",
            СтатусСообщения.Информация);
        ПодключитьОбработчикОжидания("ОбработчикАвтоРежима", ИнтервалОпроса);
    Иначе
        Сообщить("Авто-режим выключен.", СтатусСообщения.Информация);
        ОтключитьОбработчикОжидания("ОбработчикАвтоРежима");
    КонецЕсли;
КонецПроцедуры


// Вызывается таймером
Процедура ОбработчикАвтоРежима()
    Если Не АвтоРежим Тогда
        ОтключитьОбработчикОжидания("ОбработчикАвтоРежима");
        Возврат;
    КонецЕсли;

    ПапкаInbox = ПапкаДроппера + "\inbox";
    Если Не ИИ_Сервер.ПапкаСуществует(ПапкаInbox) Тогда
        Возврат;
    КонецЕсли;

    Файлы = НайтиФайлы(ПапкаInbox, "*.json");
    Для Каждого Файл Из Файлы Цикл
        Если Файл.ЭтоФайл() Тогда
            ВыполнитьЗаданиеИзФайла(Файл.ПолноеИмя);
        КонецЕсли;
    КонецЦикла;

    Если Файлы.Количество() > 0 Тогда
        ОбновитьСписокЗаданий();
        ОбновитьЖурнал();
    КонецЕсли;
КонецПроцедуры


// =============================================================================
// ЖУРНАЛ
// =============================================================================

Процедура ОбновитьЖурналНажатие(Кнопка)
    ОбновитьЖурнал();
КонецПроцедуры


Процедура ОбновитьЖурнал()
    Журнал.Очистить();

    НачалоДня = НачалоДня(ТекущаяДата());
    КонецДня = КонецДня(ТекущаяДата());

    Таблица = ИИ_Сервер.ПрочитатьЖурнал(НачалоДня, КонецДня);
    Для Каждого Стр Из Таблица Цикл
        НоваяСтр = Журнал.Добавить();
        НоваяСтр.Время = Стр.Время;
        НоваяСтр.Комментарий = Стр.Комментарий;
        НоваяСтр.Статус = Стр.Статус;
        НоваяСтр.ДлительностьМс = Стр.ДлительностьМс;
        НоваяСтр.ИдентификаторЗадания = Стр.ИдентификаторЗадания;
    КонецЦикла;

    ЭлементыФормы.Журнал.СоздатьКолонки();
КонецПроцедуры


Процедура ОткатитьВыделенноеНажатие(Кнопка)
    ТекСтрока = ЭлементыФормы.Журнал.ТекущиеДанные;
    Если ТекСтрока = Неопределено Тогда
        Сообщить("Выделите запись в журнале.");
        Возврат;
    КонецЕсли;

    Если ТекСтрока.Статус = "rolled_back" Тогда
        Сообщить("Эта запись уже откачена.");
        Возврат;
    КонецЕсли;

    Ответ = Вопрос("Выполнить обратный код для записи?" + Символы.ПС + Символы.ПС
        + "Комментарий: " + ТекСтрока.Комментарий, РежимВопроса.ДаНет);
    Если Ответ <> КодВозвратаДиалога.Да Тогда
        Возврат;
    КонецЕсли;

    Результат = ИИ_Сервер.ВыполнитьОбратныйКод(ТекСтрока.ИдентификаторЗадания);
    Сообщить("Откат: " + Результат.status + " (" + Результат.duration_ms + " мс)");
    Если ЗначениеЗаполнено(Результат.error) Тогда
        Сообщить("Ошибка отката: " + Результат.error);
    КонецЕсли;

    ОбновитьЖурнал();
КонецПроцедуры


Процедура ПросмотрКодаНажатие(Кнопка)
    ТекСтрока = ЭлементыФормы.Журнал.ТекущиеДанные;
    Если ТекСтрока = Неопределено Тогда
        Сообщить("Выделите запись.");
        Возврат;
    КонецЕсли;

    // Прочитаем код напрямую из регистра (в форме храним только сводку)
    МенеджерЗаписи = РегистрыСведений.ИИ_Действия.СоздатьМенеджерЗаписи();
    МенеджерЗаписи.ИдентификаторЗадания = ТекСтрока.ИдентификаторЗадания;
    МенеджерЗаписи.Прочитать();

    Если Не МенеджерЗаписи.Выбран() Тогда
        Сообщить("Запись не найдена.");
        Возврат;
    КонецЕсли;

    Текст = "=== Прямой код ===" + Символы.ПС
        + МенеджерЗаписи.КодПрямой + Символы.ПС + Символы.ПС
        + "=== Обратный код ===" + Символы.ПС
        + МенеджерЗаписи.КодОбратный;

    Если ЗначениеЗаполнено(МенеджерЗаписи.ТекстОшибки) Тогда
        Текст = Текст + Символы.ПС + Символы.ПС
            + "=== Ошибка ===" + Символы.ПС
            + МенеджерЗаписи.ТекстОшибки;
    КонецЕсли;

    // Открываем во временном текстовом документе
    ТекстовыйДок = Новый ТекстовыйДокумент;
    ТекстовыйДок.УстановитьТекст(Текст);
    ТекстовыйДок.Показать("Код задания " + ТекСтрока.ИдентификаторЗадания);
КонецПроцедуры


Процедура ПовторитьПрямойНажатие(Кнопка)
    ТекСтрока = ЭлементыФормы.Журнал.ТекущиеДанные;
    Если ТекСтрока = Неопределено Тогда
        Сообщить("Выделите запись.");
        Возврат;
    КонецЕсли;

    Ответ = Вопрос("Повторно выполнить прямой код?" + Символы.ПС
        + Символы.ПС + "Комментарий: " + ТекСтрока.Комментарий,
        РежимВопроса.ДаНет);
    Если Ответ <> КодВозвратаДиалога.Да Тогда
        Возврат;
    КонецЕсли;

    МенеджерЗаписи = РегистрыСведений.ИИ_Действия.СоздатьМенеджерЗаписи();
    МенеджерЗаписи.ИдентификаторЗадания = ТекСтрока.ИдентификаторЗадания;
    МенеджерЗаписи.Прочитать();
    Если Не МенеджерЗаписи.Выбран() Тогда
        Сообщить("Запись не найдена.");
        Возврат;
    КонецЕсли;

    // Создаём виртуальный JSON-задание из этой записи
    Задание = Новый Структура;
    Задание.Вставить("task_id", Строка(Новый УникальныйИдентификатор));
    Задание.Вставить("comment", "(повтор) " + МенеджерЗаписи.Комментарий);
    Задание.Вставить("code_forward", МенеджерЗаписи.КодПрямой);
    Задание.Вставить("code_backward", МенеджерЗаписи.КодОбратный);

    // Кладём в inbox как обычное задание и сразу выполняем
    ПапкаInbox = ПапкаДроппера + "\inbox";
    Если Не ИИ_Сервер.ПапкаСуществует(ПапкаInbox) Тогда
        СоздатьКаталог(ПапкаInbox);
    КонецЕсли;

    ИмяФайла = Формат(ТекущаяДата(), "ДФ='yyyyMMdd-HHmmss'") + "-replay.json";
    ПутьФайла = ПапкаInbox + "\" + ИмяФайла;

    JSON = ИИ_Сервер.СформироватьJSON(Задание);
    Запись = Новый ЗаписьТекста(ПутьФайла, КодировкаТекста.UTF8);
    Запись.Записать(JSON);
    Запись.Закрыть();

    ВыполнитьЗаданиеИзФайла(ПутьФайла);
    ОбновитьСписокЗаданий();
    ОбновитьЖурнал();
КонецПроцедуры
